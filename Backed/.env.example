# Server Configuration
PORT=8000
NODE_ENV=development

# Database
SQLITE_PATH=./data/app.db

# Security - IMPORTANT: Generate strong random secrets in production
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_minimum_32_characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS Configuration
CORS_ORIGIN=http://localhost:8888

# OpenAI API Configuration
CLIENT_OPENAI_API_KEY=your_openai_api_key_here
CLIENT_OPENAI_API_URL=https://api.siliconflow.cn/v1
CLIENT_OPENAI_MODEL=deepseek-ai/DeepSeek-V3

# Dify API Configuration (for text chat - all roles)
DIFY_API_KEY=your_dify_api_key_here
DIFY_API_URL=https://api.dify.ai/v1

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg

# Logging
LOG_LEVEL=info
LOG_FILE_PATH=./logs/app.log
